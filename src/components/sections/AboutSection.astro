---
import SectionWrapper from "../ui/SectionWrapper";
import GradientText from "../ui/GradientText";
---

<section id="about" class="py-32 relative">
  <!-- Section divider top -->
  <div class="section-divider w-full absolute top-0"></div>

  <div class="mx-auto max-w-6xl px-6">
    <SectionWrapper client:visible>
      <div class="grid md:grid-cols-5 gap-16 items-center">
        <!-- Avatar / visual — morphing blob -->
        <div class="md:col-span-2 flex justify-center">
          <div class="relative w-56 h-56 md:w-64 md:h-64">
            <!-- Animated morph blob background -->
            <div
              class="absolute inset-0 morph-blob bg-gradient-to-br from-accent/20 via-accent-secondary/10 to-accent-purple/15"
            >
            </div>
            <!-- Inner glass circle with initials -->
            <div
              class="absolute inset-4 rounded-full glass-card flex items-center justify-center
                      border border-white/[0.08]"
            >
              <span
                class="text-shimmer font-heading font-bold text-5xl md:text-6xl tracking-tighter select-none"
              >
                AJ
              </span>
            </div>
            <!-- Decorative orbiting dot -->
            <div class="absolute inset-0 animate-spin" style="animation-duration: 12s;">
              <div
                class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2
                        w-2 h-2 rounded-full bg-accent shadow-[0_0_12px_rgba(110,231,183,0.6)]"
              >
              </div>
            </div>
          </div>
        </div>

        <!-- Bio -->
        <div class="md:col-span-3 space-y-6">
          <div>
            <p class="font-mono text-xs text-accent/60 tracking-[0.25em] uppercase mb-3">
              / Sobre mí
            </p>
            <h2 class="font-heading font-bold text-3xl md:text-5xl text-white tracking-tight">
              Construyendo en la
              <br />
              <GradientText client:load>intersección</GradientText> entre
              <br />
              diseño y código
            </h2>
          </div>

          <p class="text-slate-400 leading-relaxed text-base">
            Soy un desarrollador que trabaja de forma independiente en proyectos para
            clientes, con especial interés en
            <span class="text-white font-medium"> Flutter</span> para móvil y
            <span class="text-white font-medium"> Astro</span> para la web. Me enfoco en
            crear interfaces cuidadas, buen rendimiento y una base técnica sólida.
          </p>
          <p class="text-slate-500 leading-relaxed text-sm">
            Trabajo cada proyecto de principio a fin por mi cuenta, cuidando la
            arquitectura, las animaciones, los componentes reutilizables y la calidad final de la experiencia.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-3 pt-4">
            <div class="glass-card holo-border p-5 text-center group">
              <p class="font-heading font-bold text-3xl text-white group-hover:text-shimmer transition-colors">
                Flutter
              </p>
              <p class="font-mono text-[10px] text-slate-500 mt-1.5 tracking-wider uppercase">
                Desarrollo móvil
              </p>
            </div>
            <div class="glass-card holo-border p-5 text-center group">
              <p class="font-heading font-bold text-3xl text-white group-hover:text-shimmer transition-colors">
                Astro
              </p>
              <p class="font-mono text-[10px] text-slate-500 mt-1.5 tracking-wider uppercase">
                Desarrollo web
              </p>
            </div>
            <div class="glass-card holo-border p-5 text-center group">
              <p class="font-heading font-bold text-3xl text-white group-hover:text-shimmer transition-colors">
                UI
              </p>
              <p class="font-mono text-[10px] text-slate-500 mt-1.5 tracking-wider uppercase">
                Detalle y rendimiento
              </p>
            </div>
          </div>
        </div>
      </div>
    </SectionWrapper>
  </div>
</section>
