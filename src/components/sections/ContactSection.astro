---
import SectionWrapper from "../ui/SectionWrapper";
---

<section id="contact" class="py-32 relative">
  <div class="section-divider w-full absolute top-0"></div>

  <!-- Glow bg -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-accent/[0.04] blur-[160px] pointer-events-none"></div>

  <div class="mx-auto max-w-6xl px-6">
    <SectionWrapper client:visible>
      <div class="relative max-w-2xl mx-auto text-center">
        <!-- Pulsating decorative rings with staggered delays -->
        <div class="absolute top-1/2 left-1/2 w-[500px] h-[500px] rounded-full border border-accent/[0.04] pointer-events-none ring-pulse" style="animation-delay: 0s;"></div>
        <div class="absolute top-1/2 left-1/2 w-[400px] h-[400px] rounded-full border border-accent-secondary/[0.05] pointer-events-none ring-pulse" style="animation-delay: -1s;"></div>
        <div class="absolute top-1/2 left-1/2 w-[300px] h-[300px] rounded-full border border-accent-purple/[0.06] pointer-events-none ring-pulse" style="animation-delay: -2s;"></div>
        <div class="absolute top-1/2 left-1/2 w-[200px] h-[200px] rounded-full border border-accent/[0.04] pointer-events-none ring-pulse" style="animation-delay: -3s;"></div>

        <div class="relative glass-card holo-border p-10 md:p-14 space-y-8">
          <div>
            <p class="font-mono text-xs text-accent/60 tracking-[0.25em] uppercase mb-4">
              / Contacto
            </p>
            <h2 class="font-heading font-bold text-3xl md:text-5xl text-white tracking-tight mb-4">
              Construyamos<br />
              <span class="text-shimmer">algo grande</span>
            </h2>
            <p class="text-slate-500 text-sm leading-relaxed max-w-md mx-auto">
              Siempre estoy abierto a hablar sobre nuevos proyectos, ideas creativas
              u oportunidades. Escríbeme.
            </p>
          </div>

          <!-- Email with particle burst on hover -->
          <div class="relative">
            <a
              id="email-cta"
              href="mailto:ajesusdl27@email.com"
              class="group inline-flex items-center gap-3 px-6 py-3.5 rounded-2xl
                     border border-white/[0.06] bg-white/[0.02]
                     hover:border-accent/30 hover:bg-accent/5
                     transition-all duration-500 relative overflow-visible"
            >
              <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              <span class="font-mono text-sm text-slate-300 group-hover:text-white transition-colors">
                ajesusdl27@email.com
              </span>
              <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-accent group-hover:translate-x-0.5 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </a>
            <!-- Particle container for burst effect -->
            <div id="email-particles" class="absolute inset-0 pointer-events-none" aria-hidden="true"></div>
          </div>

          <!-- Social links -->
          <div class="flex justify-center gap-3">
            <a
              href="https://github.com/ajesusdl27"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center w-11 h-11 rounded-xl
                     border border-white/[0.06] bg-white/[0.02]
                     hover:border-accent/30 hover:bg-accent/5
                     text-slate-500 hover:text-white transition-all duration-300"
              aria-label="GitHub"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"></path>
              </svg>
            </a>
            <a
              href="https://linkedin.com/in/antonio-jes%C3%BAs-dom%C3%ADnguez-l%C3%B3pez-3882b5385/"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center w-11 h-11 rounded-xl
                     border border-white/[0.06] bg-white/[0.02]
                     hover:border-accent/30 hover:bg-accent/5
                     text-slate-500 hover:text-white transition-all duration-300"
              aria-label="LinkedIn"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </SectionWrapper>
  </div>
</section>

<script>
  // Email hover: particle burst effect
  const emailCta = document.getElementById("email-cta");
  const particleContainer = document.getElementById("email-particles");

  if (emailCta && particleContainer) {
    let hasPlayed = false;
    emailCta.addEventListener("mouseenter", () => {
      if (hasPlayed) return;
      hasPlayed = true;

      const colors = ["#6EE7B7", "#22D3EE", "#A78BFA", "#EC4899"];
      const rect = emailCta.getBoundingClientRect();
      const containerRect = particleContainer.getBoundingClientRect();

      for (let i = 0; i < 16; i++) {
        const dot = document.createElement("div");
        const angle = (Math.PI * 2 * i) / 16;
        const distance = 40 + Math.random() * 50;
        const tx = Math.cos(angle) * distance;
        const ty = Math.sin(angle) * distance;
        const size = 2 + Math.random() * 3;

        Object.assign(dot.style, {
          position: "absolute",
          left: `${(rect.width / 2) - (size / 2)}px`,
          top: `${(rect.height / 2) - (size / 2)}px`,
          width: `${size}px`,
          height: `${size}px`,
          borderRadius: "50%",
          background: colors[Math.floor(Math.random() * colors.length)],
          transition: `all ${0.5 + Math.random() * 0.4}s cubic-bezier(0.25,0.46,0.45,0.94)`,
          opacity: "1",
          pointerEvents: "none",
        });

        particleContainer.appendChild(dot);

        // Trigger animation after append
        requestAnimationFrame(() => {
          dot.style.transform = `translate(${tx}px, ${ty}px) scale(0)`;
          dot.style.opacity = "0";
        });

        setTimeout(() => dot.remove(), 1000);
      }

      // Reset after cooldown
      setTimeout(() => { hasPlayed = false; }, 1500);
    });
  }
</script>
