---
const navLinks = [
  { label: "Sobre mí", href: "#about" },
  { label: "Habilidades", href: "#skills" },
  { label: "Proyectos", href: "#projects" },
  { label: "Experiencia", href: "#experience" },
  { label: "Contacto", href: "#contact" },
];
---

<nav
  id="main-nav"
  class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-auto transition-all duration-500"
>
  <div
    class="flex items-center gap-1 px-2 py-2
           bg-white/[0.03] backdrop-blur-2xl border border-white/[0.06]
           rounded-2xl shadow-[0_0_40px_rgba(0,0,0,0.3)]"
  >
    <!-- Logo -->
    <a
      href="#hero"
      class="flex items-center justify-center w-9 h-9 rounded-xl
             bg-accent/10 text-accent font-heading font-bold text-sm
             hover:bg-accent/20 transition-colors shrink-0"
    >
      AJ
    </a>

    <!-- Desktop links with floating pill -->
    <ul class="hidden md:flex items-center gap-0.5 ml-1 relative">
      <!-- Animated floating pill indicator -->
      <li
        id="nav-pill"
        class="absolute rounded-xl bg-white/[0.08] border border-accent/20
               transition-all duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)]
               pointer-events-none opacity-0 shadow-[0_0_12px_rgba(110,231,183,0.08)]"
        style="height: calc(100% - 4px); top: 2px;"
        aria-hidden="true"
      ></li>
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              data-nav-link
              class="relative z-10 px-3.5 py-2 text-xs font-medium text-slate-500
                     hover:text-white transition-colors duration-300 rounded-xl"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-9 h-9 rounded-xl
             text-slate-500 hover:text-white hover:bg-white/[0.04] transition-all ml-1"
      aria-label="Abrir o cerrar menú"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden mt-2 bg-white/[0.03] backdrop-blur-2xl
           border border-white/[0.06] rounded-2xl overflow-hidden
           shadow-[0_0_40px_rgba(0,0,0,0.3)]"
  >
    <ul class="flex flex-col p-2 gap-0.5">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              data-mobile-nav-link
              class="block px-4 py-2.5 text-xs font-medium text-slate-500
                     hover:text-white hover:bg-white/[0.04] rounded-xl transition-all"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
  document.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
    link.addEventListener("click", () => menu?.classList.add("hidden"));
  });

  // Floating pill indicator
  const pill = document.getElementById("nav-pill") as HTMLElement | null;
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const navContainer = pill?.parentElement;

  function movePill(activeLink: HTMLAnchorElement) {
    if (!pill || !navContainer) return;
    const containerRect = navContainer.getBoundingClientRect();
    const linkRect = activeLink.getBoundingClientRect();

    pill.style.left = `${linkRect.left - containerRect.left}px`;
    pill.style.width = `${linkRect.width}px`;
    pill.style.opacity = "1";
  }

  // Active link via IntersectionObserver
  const sections = document.querySelectorAll("section[id]");
  let currentActive: HTMLAnchorElement | null = null;

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            if (href === `#${entry.target.id}`) {
              link.classList.add("text-white");
              link.classList.remove("text-slate-500");
              currentActive = link;
              movePill(link);
            } else {
              link.classList.remove("text-white");
              link.classList.add("text-slate-500");
            }
          });
        }
      });
    },
    { rootMargin: "-20% 0px -75% 0px" }
  );

  sections.forEach((section) => observer.observe(section));

  // Hover preview + return to active
  navLinks.forEach((link) => {
    link.addEventListener("mouseenter", () => movePill(link));
    link.addEventListener("mouseleave", () => {
      if (currentActive) movePill(currentActive);
      else if (pill) pill.style.opacity = "0";
    });
  });
</script>
